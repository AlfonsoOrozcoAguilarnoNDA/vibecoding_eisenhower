// Configuración de Zona Horaria y Conexión
date_default_timezone_set('America/Mexico_City');
include "config.php"; // Provee el objeto $link (mysqli)

// Auto-referencia para el formulario
$self = htmlspecialchars($_SERVER['PHP_SELF']);

// Mensajes de retroalimentación
$mensaje = "";
$tipo_mensaje = "";

// --- PROCESAMIENTO CRUD (Procedural) ---

// 1. Guardar o Actualizar
if (isset($_POST['action']) && $_POST['action'] == 'save') {
    $id = isset($_POST['id']) ? intval($_POST['id']) : 0;
    $categoria = trim($_POST['categoria'] ?? '');
    $urgencia = trim($_POST['urgencia'] ?? '');
    $asunto = trim($_POST['asunto'] ?? '');
    $descripcion = trim($_POST['descripcion'] ?? '');
    $comentario = trim($_POST['comentario'] ?? '');
    $fecha_compromiso = trim($_POST['fecha_compromiso'] ?? '');
    $fecha_registro = date('Y-m-d H:i:s');

    // Validación de obligatoriedad y longitudes máximas
    if ($categoria === '' || $urgencia === '' || $asunto === '' || $descripcion === '' || $comentario === '' || $fecha_compromiso === '') {
        $mensaje = "Todos los campos son estrictamente obligatorios.";
        $tipo_mensaje = "danger";
    } elseif (mb_strlen($descripcion) > 40) {
        $mensaje = "La descripción no puede exceder los 40 caracteres.";
        $tipo_mensaje = "danger";
    } elseif (mb_strlen($comentario) > 80) {
        $mensaje = "El comentario no puede exceder los 80 caracteres.";
        $tipo_mensaje = "danger";
    } else {
        if ($id > 0) {
            // Modificación
            $stmt = mysqli_prepare($link, "UPDATE pendientes SET categoria=?, urgencia=?, asunto=?, descripcion=?, comentario=?, fecha_compromiso=? WHERE id=?");
            mysqli_stmt_bind_param($stmt, "ssssssi", $categoria, $urgencia, $asunto, $descripcion, $comentario, $fecha_compromiso, $id);
        } else {
            // Inserción
            $stmt = mysqli_prepare($link, "INSERT INTO pendientes (categoria, urgencia, asunto, descripcion, comentario, fecha_compromiso, fecha_registro) VALUES (?, ?, ?, ?, ?, ?, ?)");
            mysqli_stmt_bind_param($stmt, "sssssss", $categoria, $urgencia, $asunto, $descripcion, $comentario, $fecha_compromiso, $fecha_registro);
        }

        if (mysqli_stmt_execute($stmt)) {
            $mensaje = ($id > 0) ? "Pendiente actualizado con éxito." : "Pendiente guardado correctamente.";
            $tipo_mensaje = "success";
        } else {
            $mensaje = "Error en la base de datos: " . mysqli_error($link);
            $tipo_mensaje = "danger";
        }
        mysqli_stmt_close($stmt);
    }
}

// 2. Eliminar
if (isset($_POST['action']) && $_POST['action'] == 'delete') {
    $id = isset($_POST['id']) ? intval($_POST['id']) : 0;
    $confirmar = isset($_POST['confirmar_borrado']) ? true : false;

    if ($id > 0 && $confirmar) {
        $stmt = mysqli_prepare($link, "DELETE FROM pendientes WHERE id = ?");
        mysqli_stmt_bind_param($stmt, "i", $id);
        if (mysqli_stmt_execute($stmt)) {
            $mensaje = "Registro eliminado correctamente.";
            $tipo_mensaje = "success";
        } else {
            $mensaje = "Error al eliminar: " . mysqli_error($link);
            $tipo_mensaje = "danger";
        }
        mysqli_stmt_close($stmt);
    } else {
        $mensaje = "Debe confirmar el checkbox para poder eliminar el registro.";
        $tipo_mensaje = "warning";
    }
}

// 3. Cargar datos para edición
$edit_data = null;
if (isset($_GET['edit'])) {
    $edit_id = intval($_GET['edit']);
    $result_edit = mysqli_query($link, "SELECT * FROM pendientes WHERE id = $edit_id");
    if ($result_edit && mysqli_num_rows($result_edit) > 0) {
        $edit_data = mysqli_fetch_assoc($result_edit);
    }
}

// --- CONSULTAS PARA MÉTRICAS Y TABLA ---

// Listado general de pendientes
$result_list = mysqli_query($link, "SELECT * FROM pendientes ORDER BY fecha_compromiso ASC");

// Cálculo de días de la tarea más antigua (basado en fecha_registro)
$dias_antigua = 0;
$res_antigua = mysqli_query($link, "SELECT fecha_registro FROM pendientes ORDER BY fecha_registro ASC LIMIT 1");
if ($res_antigua && mysqli_num_rows($res_antigua) > 0) {
    $row_antigua = mysqli_fetch_assoc($res_antigua);
    $fecha_ant_dt = new DateTime($row_antigua['fecha_registro']);
    $hoy_dt = new DateTime();
    $intervalo = $hoy_dt->diff($fecha_ant_dt);
    $dias_antigua = $intervalo->days;
}

// Contadores de Urgencia
$urgencias_validas = [
    'Urgente' => 0,
    'Importante' => 0,
    'Urgente Importante' => 0,
    'Importante no Urgente' => 0
];
$total_pendientes = 0;

$res_metricas = mysqli_query($link, "SELECT urgencia, COUNT(*) as total FROM pendientes GROUP BY urgencia");
while ($row = mysqli_fetch_assoc($res_metricas)) {
    if (isset($urgencias_validas[$row['urgencia']])) {
        $urgencias_validas[$row['urgencia']] = intval($row['total']);
        $total_pendientes += intval($row['total']);
    }
}

// Obtener IP del cliente de forma segura
$ip_cliente = $_SERVER['REMOTE_ADDR'] ?? '127.0.0.1';
if (!empty($_SERVER['HTTP_X_FORWARDED_FOR'])) {
    $ip_cliente = explode(',', $_SERVER['HTTP_X_FORWARDED_FOR'])[0];
}
