    <script>
        // Funciones de validación e interfaz en lado del cliente
        function confirmarSalida(e) {
            e.preventDefault();
            if (confirm("¿Está usted seguro de que desea salir del sistema?")) {
                window.location.href = "https://google.com";
            }
        }

        function confirmarBorrado(form) {
            const checkbox = form.querySelector('input[name="confirmar_borrado"]');
            if (!checkbox.checked) {
                alert("Operación denegada: Debe marcar el checkbox de confirmación junto al botón de eliminar.");
                return false;
            }
            return confirm("¿Confirmar eliminación permanente de este registro?");
        }

        // Manejo interactivo de contadores de caracteres en tiempo real
        function setupCounter(inputId, counterId, maxLen) {
            const input = document.getElementById(inputId);
            const counter = document.getElementById(counterId);
            
            if(input && counter) {
                const update = () => {
                    counter.innerText = `${input.value.length}/${maxLen}`;
                };
                input.addEventListener('input', update);
                update(); // Ejecución inicial (carga)
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            setupCounter('descripcion', 'desc-count', 40);
            setupCounter('comentario', 'com-count', 80);
        });
    </script>
